{
  "name": "hellosearch",
  "version": "0.1.0",
  "description": "基于当前环境原生搜索与页面读取能力的真实搜索 skill，用于最新信息核验、官网文档查证、来源对比与证据化整理。",
  "type": "module",
  "private": false,
  "bin": {
    "hellosearch": "bin/hellosearch.mjs"
  },
  "files": [
    "SKILL.md",
    "agents",
    "references",
    "scripts",
    "bin",
    "lib"
  ],
  "scripts": {
    "test:python": "python -B -m unittest discover -s \"./tests\" -v",
    "test:node": "node --test \"node-tests/**/*.test.mjs\"",
    "test": "npm run test:node && npm run test:python",
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "skill",
    "search",
    "web-research",
    "fact-verification",
    "evidence-synthesis",
    "official-sources",
    "workflow"
  ],
  "author": "hellowind",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hellowind777/hellosearch.git"
  },
  "homepage": "https://github.com/hellowind777/hellosearch",
  "bugs": {
    "url": "https://github.com/hellowind777/hellosearch/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
